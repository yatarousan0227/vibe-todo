DATABASE_URL=postgres://vibetodo:vibetodo@localhost:5432/vibetodo

# ============================================================
# LLM Provider Selection (required)
# Allowed values: openai, anthropic, azure_openai
# ============================================================
LLM_PROVIDER=azure_openai

# ============================================================
# OpenAI Provider Configuration (required when LLM_PROVIDER=openai)
# ============================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# ============================================================
# Anthropic Provider Configuration (required when LLM_PROVIDER=anthropic)
# ============================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com

# ============================================================
# Azure OpenAI Provider Configuration (required when LLM_PROVIDER=azure_openai)
# ============================================================
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.1-chat
AZURE_OPENAI_API_VERSION=2024-02-01
